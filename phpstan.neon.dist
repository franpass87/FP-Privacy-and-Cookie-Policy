# Analisi incrementale: REST, Domain, Application, Providers (+ facade Integrations); espandere verso tutto `src/` gradualmente.
parameters:
    level: 5
    paths:
        - src/REST
        - src/Integrations/ServiceRegistry.php
        - src/Domain
        - src/Application
        - src/Providers
    scanFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
