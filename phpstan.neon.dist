# Analisi statica su tutto `src/` (livello 5); bootstrap e stub WP-CLI per analisi locale.
parameters:
    bootstrapFiles:
        - tools/phpstan-bootstrap.php
    level: 5
    paths:
        - src
    scanFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
        - tools/phpstan-wp-cli-stubs.php
