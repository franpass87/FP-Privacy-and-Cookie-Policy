# Analisi incrementale: `src/REST`, `src/Domain`, `src/Application` (+ facade Integrations); espandere verso tutto `src/` gradualmente.
parameters:
    level: 5
    paths:
        - src/REST
        - src/Integrations/ServiceRegistry.php
        - src/Domain
        - src/Application
    scanFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
