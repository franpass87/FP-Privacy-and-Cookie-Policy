# Analisi incrementale: REST, Domain, Application, Providers (+ facade Integrations); espandere verso tutto `src/` gradualmente.
parameters:
    bootstrapFiles:
        - tools/phpstan-bootstrap.php
    level: 5
    paths:
        - src/REST
        - src/Integrations/ServiceRegistry.php
        - src/Domain
        - src/Application
        - src/Providers
        - src/Utils
        - src/Frontend
        - src/Infrastructure
        - src/Consent
        - src/Admin
        - src/Presentation
    scanFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
        - tools/phpstan-wp-cli-stubs.php
