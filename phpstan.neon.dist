# Analisi incrementale: espandere `paths` verso tutto `src/` quando la memoria CI lo consente.
parameters:
    level: 5
    paths:
        - src/REST
        - src/Integrations/ServiceRegistry.php
        - src/Domain/Services/ServiceRegistry.php
    scanFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
